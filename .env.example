# ============================================
# Claude Chat 环境变量配置
# 复制此文件为 .env 并填入你的密钥
#
# Copy this file to .env and fill in your keys
# ============================================

# 火山方舟 API Key（推荐，国内直达）
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
ARK_API_KEY=your-ark-api-key-here

# Anthropic API Key（需要科学上网）
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek API Key
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# OpenAI API Key
# Get from: https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key-here

# 火山引擎 AK/SK（用于查询账单）
# Volcano Engine Access Key / Secret Key (for billing query)
BYTEPLUS_ACCESS_KEY=your-byteplus-ak
BYTEPLUS_SECRET_KEY=your-byteplus-sk
